# Database (Docker container values — override locally)
OPT_DB_SERVER=host.docker.internal\SQLEXPRESS
OPT_DB_NAME=OptionsAdvisorDB
OPT_DB_USER=
OPT_DB_PASSWORD=
OPT_DB_TIMEOUT=30
OPT_DB_CREATE_IF_MISSING=true

# Dashboard
OPT_DASHBOARD_HOST=0.0.0.0
OPT_DASHBOARD_PORT=5001
OPT_DASHBOARD_DEBUG=false

# Logging
OPT_LOG_CONSOLE_LEVEL=INFO
OPT_LOG_FILE_LEVEL=INFO
OPT_LOG_DB_LEVEL=INFO
OPT_LOG_DIR=logs

# Email alerts (off by default)
OPT_EMAIL_ENABLED=false
OPT_SMTP_HOST=
OPT_SMTP_PORT=587
OPT_SMTP_USER=
OPT_SMTP_PASSWORD=
OPT_SMTP_FROM=
OPT_SMTP_TO=
OPT_SMTP_USE_TLS=true

# Trading Economics API — free tier for auto economic calendar
# Register at https://tradingeconomics.com/api/ (no credit card)
# Leave blank to use static EVENTS_CONFIG list from config.py instead
OPT_TE_API_KEY=
